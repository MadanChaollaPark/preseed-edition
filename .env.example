# Copy to .env.local and fill in your ElevenLabs API key.
# WARNING: VITE_-prefixed vars are inlined into the client bundle, so this
# key will be visible to anyone who opens devtools on a deployed build.
# For hackathon-local use only — proxy through a backend before shipping.
VITE_ELEVENLABS_API_KEY=

# Default fallback voice.
VITE_ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Character-specific voices. Override these to give each speaker a distinct voice.
# Marc defaults to the fallback voice.
VITE_ELEVENLABS_VOICE_MARC=21m00Tcm4TlvDq8ikWAM
VITE_ELEVENLABS_VOICE_BRETT=TxGEqnHWrfWFTfGW9XjX
VITE_ELEVENLABS_VOICE_ANNOUNCER=VR6AewLTigWG4xSOukaG
VITE_ELEVENLABS_VOICE_JUDGE=EXAVITQu4vr4xnSDxMaL
